<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:UP_4.Converters"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP_4.Views.MainPageView"
             xmlns:vm="clr-namespace:UP_4.ViewModels"
             x:DataType="vm:MainPageViewModel">

    <UserControl.Resources>
        <local:Base64ToImageConverter x:Key="Base64ToImageConverter"/>
        <local:InvertedBooleanConverter x:Key="InvertBool"/>
    </UserControl.Resources>

    <Grid RowDefinitions="60, 40, *" ColumnDefinitions="250, *">

        <!-- Шапка -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White">
            <Grid ColumnDefinitions="80*, 20*">
                <Image Grid.Column="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Source="/Assets/Logo.png"/>
                <Border Grid.Column="1">
                    <Grid ColumnDefinitions="30*, 70*">
                        <Image Grid.Column="0" Source="{Binding CurrentUser.Image, Converter={StaticResource Base64ToImageConverter}}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser.ShortName}"/>
                            <TextBlock Text="{Binding CurrentUser.IdRoleNavigation.Name}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Верхняя панель -->
        <Grid Grid.Row="1" ColumnDefinitions="70*, 30*">
            <Border Grid.Column="0" Background="#1d2127">
                <TextBlock Text="Навигация"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Foreground="White"
                           Padding="5"/>
            </Border>
            <Border Grid.Column="1" Background="#171717">
                <TextBlock Text="☰"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Левое меню -->
        <Border Grid.Column="0" Grid.Row="2" Background="#1d2127">
            <Border.Styles>
                <Style Selector="Expander /template/ ToggleButton">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#171717"/>
                </Style>
            </Border.Styles>
            <StackPanel Margin="10">
               <Button Content="Главная"
                       Command="{Binding GoToHomeCommand}"
                       Margin="0,0,0,10"
                       Width="230" Height="50"
                       Foreground="White" Background="#171717"
                       HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Padding="15,0,0,0"/>
                <Expander Header="Администрирование"
                          Width="230"
                          Foreground="White"
                          Background="#1d2127">
                    <StackPanel>
                        <Button Content="Торговые автоматы"
                                Command="{Binding GoToMachinesCommand}"
                                Width="200" Margin="0,0,0,10"
                                Foreground="White" Background="#171717"/>
                        <Button Content="Список компаний"
                                Width="200"
                                Foreground="White"
                                Background="#171717"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Верхняя часть правой колонки -->
        <Border Grid.Row="1" Grid.Column="1" Background="#171717">
            <Grid ColumnDefinitions="80*, 20*">
                <TextBlock Text="ООО Торговые Автоматы"
                           Grid.Column="0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Padding="5"
                           Foreground="White"/>
                <TextBlock Text="Главная"
                           Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="Gray"/>
            </Grid>
        </Border>

        <!-- Основная область контента -->
        <Border Grid.Row="2" Grid.Column="1" Background="#d9d9d9">
            <Grid RowDefinitions="50, *">
                <Border Grid.Row="0" Background="#d9d9d9">
                    <TextBlock Text="Личный кабинет. Главная"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Padding="15"/>
                </Border>

                <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, *, *" Margin="10" RowSpacing="10" ColumnSpacing="10">

                        <!-- Блок 1: Эффективность сети (спидометр) -->
                        <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Эффективность сети" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <lvc:PieChart Series="{Binding GaugeSeries}"
                                              MaxAngle="180" 
                                              InitialRotation="180"
                                              Height="150" 
                                              Width="150"
                                              HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding NetworkEfficiency, StringFormat='{}{0:F1}% работающих автоматов'}"
                                           FontSize="14" Foreground="Gray" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>
                        
                        <!-- Блок 2: Состояние сети (круговая диаграмма) -->
                        <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Состояние сети" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <lvc:PieChart Series="{Binding PieSeries}"
                                              Height="150" Width="150"
                                              HorizontalAlignment="Center"/>
                                <Grid Margin="0,10,0,0" ColumnDefinitions="*,*,*">
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Rectangle Fill="Green" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="Работает"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Rectangle Fill="Red" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="Не работает"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                        <Rectangle Fill="Orange" Width="12" Height="12" Margin="0,0,4,0"/>
                                        <TextBlock Text="Обслуживание"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Блок 3: Сводка -->
                        <Border Grid.Row="0" Grid.Column="2" Background="White" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Сводка" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <Grid RowDefinitions="Auto, Auto, Auto">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Продажи:"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SummaryData.TotalSales, StringFormat='{}{0:N2} руб'}" 
                                               HorizontalAlignment="Right" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Инкассация:"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SummaryData.CashCollection, StringFormat='{}{0:N2} руб'}" 
                                               HorizontalAlignment="Right" FontWeight="Bold"/>
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="ТА на обслуживании:"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SummaryData.MachinesUnderMaintenance}" 
                                               HorizontalAlignment="Right" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Блок 4: Динамика продаж -->
                        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="White" CornerRadius="8" Padding="10">
                            <StackPanel>
                                
                            </StackPanel>
                        </Border>

                        <!-- Блок 5: Новости -->
                        <Border Grid.Row="1" Grid.Column="2" Background="White" CornerRadius="8" Padding="10">
                            <StackPanel>
                                <TextBlock Text="Новости" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
                                <ListBox ItemsSource="{Binding News}" Background="Transparent" BorderThickness="0" MaxHeight="200">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="LightGray" BorderThickness="0,0,0,1" Padding="5">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding Content}" TextWrapping="Wrap"/>
                                                    <TextBlock Text="{Binding PublishDate, StringFormat='dd.MM.yyyy'}" FontSize="10" Foreground="Gray"/>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </StackPanel>
                        </Border>

                    </Grid>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>