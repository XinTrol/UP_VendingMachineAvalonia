<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP_4.Views.VendingMachinesView"
             xmlns:vm="clr-namespace:UP_4.ViewModels"
             x:DataType="vm:VendingMachinesViewModel">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 1. Панель управления -->
        <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,15">
            <TextBlock Text="Торговые автоматы" FontSize="24" FontWeight="Bold"/>
            
            <DockPanel LastChildFill="True">
                <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Right">
                    <Button Content="Таблица" Command="{Binding ToggleViewCommand}" CommandParameter="Table" 
                            IsEnabled="{Binding !IsTableView}"/>
                    <Button Content="Плитка" Command="{Binding ToggleViewCommand}" CommandParameter="Tile" 
                            IsEnabled="{Binding IsTableView}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Spacing="10">
                    <TextBox Watermark="Поиск по названию..." Text="{Binding SearchText, Mode=TwoWay}" Width="200"/>
                    <Button Content="Экспорт в CSV" Command="{Binding ExportCsvCommand}"/>
                </StackPanel>
            </DockPanel>
        </StackPanel>

        <!-- 2. Область отображения данных -->
        <Grid Grid.Row="1">
           <!-- Режим Таблицы -->
            <DataGrid Name="DgMachines" 
                      ItemsSource="{Binding DisplayedMachines}" 
                      IsVisible="{Binding IsTableView}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      BorderThickness="1"
                      BorderBrush="Gray"
                      SelectionMode="Single">
            
                <!-- Настройка чередующегося цвета строк через Стили -->
                <DataGrid.Styles>
                    <Style Selector="DataGridRow:nth-child(even)">
                        <Setter Property="Background" Value="#F0F0F0"/>
                    </Style>
                </DataGrid.Styles>
            
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="*"/>
                    <DataGridTextColumn Header="Название автомата" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Модель" Binding="{Binding ModelNavigation.Name}" Width="*"/>
                    <DataGridTextColumn Header="Компания" Binding="{Binding CompanyNavigation.Name}" Width="*"/>
                    <DataGridTextColumn Header="Модем" Binding="{Binding KitOnlineId}" Width="*"/>
                    <DataGridTextColumn Header="Адрес/Место" Binding="{Binding PlaceNavigation.Name}" Width="*"/>
                    <DataGridTextColumn Header="В работе с" Binding="{Binding InstallDate}" Width="*"/>
            
                    <!-- Колонка Действия -->
                    <DataGridTemplateColumn Header="Действия" Width="200">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5">
                                    <Button Content="✏️" ToolTip.Tip="Редактировать" 
                                            Command="{Binding $parent[DataGrid].((vm:VendingMachinesViewModel)DataContext).EditMachineCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="❌" ToolTip.Tip="Удалить" 
                                            Command="{Binding $parent[DataGrid].((vm:VendingMachinesViewModel)DataContext).DeleteMachineCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="📶" ToolTip.Tip="Отвязать модем" 
                                            Command="{Binding $parent[DataGrid].((vm:VendingMachinesViewModel)DataContext).UnlinkModemCommand}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Режим Плитки -->
            <ItemsControl ItemsSource="{Binding DisplayedMachines}" 
                          IsVisible="{Binding !IsTableView}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="250" Height="180" Margin="10" Background="White" 
                                BorderBrush="#DDD" BorderThickness="1" CornerRadius="5" 
                                Padding="10">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16"/>
                                <TextBlock Text="{Binding ModelNavigation.Name}" Foreground="Gray"/>
                                <TextBlock Text="{Binding CompanyNavigation.Name}"/>
                                <TextBlock Text="{Binding PlaceNavigation.Name}" TextWrapping="Wrap"/>
                                
                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,10,0,0">
                                    <Button Content="Редакт." 
                                            Command="{Binding $parent[ItemsControl].((vm:VendingMachinesViewModel)DataContext).EditMachineCommand}"
                                            CommandParameter="{Binding}"/>
                                    <Button Content="Удалить" 
                                            Command="{Binding $parent[ItemsControl].((vm:VendingMachinesViewModel)DataContext).DeleteMachineCommand}"
                                            CommandParameter="{Binding}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Grid>

        <!-- 3. Пагинация -->
        <DockPanel Grid.Row="2" Margin="0,15,0,0" LastChildFill="False">
            <TextBlock Text="{Binding ItemsInfo}" DockPanel.Dock="Left" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Left" Margin="20,0,0,0">
                <TextBlock Text="Строк на странице:" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding ItemsPerPageOptions}" 
                          SelectedItem="{Binding ItemsPerPage}"
                          Width="60"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="5" DockPanel.Dock="Right">
                <!-- ИСПРАВЛЕНО: Заменены спецсимволы < и > -->
                <Button Content="&lt;" Command="{Binding PrevPageCommand}"/>
                <TextBlock Text="{Binding CurrentPage}" VerticalAlignment="Center" Margin="5,0"/>
                <TextBlock Text="/" VerticalAlignment="Center"/>
                <TextBlock VerticalAlignment="Center" Text="{Binding TotalPages}"/>
                <Button Content="&gt;" Command="{Binding NextPageCommand}"/>
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>