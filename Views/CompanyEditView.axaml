<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:UP_4.Converters"
             xmlns:vm="clr-namespace:UP_4.ViewModels"
             mc:Ignorable="d"
             x:Class="UP_4.Views.CompanyEditView"
             x:DataType="vm:CompanyEditViewModel"
             d:DesignWidth="800" d:DesignHeight="600">

    <UserControl.Styles>
        <Style Selector="TextBlock.header">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,10,0,5"/>
        </Style>
        <Style Selector="TextBox, ComboBox">
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Заголовок -->
        <Border Background="White" Padding="10">
            <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="Bold"/>
        </Border>

        <!-- Форма -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20" Spacing="10">
                <Grid ColumnDefinitions="*,*" RowSpacing="10" ColumnSpacing="20">
                    <!-- Левая колонка -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Classes="header" Text="Название *"/>
                        <TextBox Text="{Binding Name}"/>

                        <TextBlock Classes="header" Text="Адрес"/>
                        <TextBox Text="{Binding Address}"/>

                        <TextBlock Classes="header" Text="Телефон"/>
                        <TextBox Text="{Binding Phone}"/>
                    </StackPanel>

                    <!-- Правая колонка -->
                    <StackPanel Grid.Column="1">
                        <TextBlock Classes="header" Text="Email"/>
                        <TextBox Text="{Binding Email}"/>

                        <TextBlock Classes="header" Text="ИНН *"/>
                        <TextBox Text="{Binding Inn}"/>

                        <TextBlock Classes="header" Text="Вышестоящая компания"/>
                        <ComboBox ItemsSource="{Binding Companies}"
                                  SelectedItem="{Binding SelectedParentCompany}"
                                  DisplayMemberBinding="{Binding Name}"/>
                    </StackPanel>
                </Grid>

                <!-- Кнопки -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="20" Margin="0,20,0,0">
                    <Button Content="Сохранить" Command="{Binding SaveCommand}" Padding="30,10"/>
                    <Button Content="Отмена" Command="{Binding CancelCommand}" Padding="30,10"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>