<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:local="clr-namespace:UP_4.Converters"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP_4.Views.MainPageView"
             xmlns:vm="clr-namespace:UP_4.ViewModels"
             x:DataType="vm:MainPageViewModel">

    <UserControl.Resources>
        <local:Base64ToImageConverter x:Key="Base64ToImageConverter"/>
        <local:InvertedBooleanConverter x:Key="InvertBool"/>
    </UserControl.Resources>

    <Grid RowDefinitions="60, 40, *" ColumnDefinitions="250, *">

        <!-- Шапка (без изменений) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="White">
            <Grid ColumnDefinitions="80*, 20*">
                <Image Grid.Column="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Source="/Assets/Logo.png"/>
                <Border Grid.Column="1">
                    <Grid ColumnDefinitions="30*, 70*">
                        <Image Grid.Column="0" Source="{Binding CurrentUser.Image, Converter={StaticResource Base64ToImageConverter}}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentUser.ShortName}"/>
                            <TextBlock Text="{Binding CurrentUser.IdRoleNavigation.Name}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Верхняя панель (без изменений) -->
        <Grid Grid.Row="1" ColumnDefinitions="70*, 30*">
            <Border Grid.Column="0" Background="#1d2127">
                <TextBlock Text="Навигация"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Foreground="White"
                           Padding="5"/>
            </Border>
            <Border Grid.Column="1" Background="#171717">
                <TextBlock Text="☰"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <!-- Левое меню (без изменений) -->
        <Border Grid.Column="0" Grid.Row="2" Background="#1d2127">
            <Border.Styles>
                <Style Selector="Expander /template/ ToggleButton">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#171717"/>
                </Style>
            </Border.Styles>
            <StackPanel Margin="10">
                <Button Content="Главная"
                        Command="{Binding GoToHomeCommand}"
                        Margin="0,0,0,10"
                        Width="230" Height="50"
                        Foreground="White" Background="#171717"
                        HorizontalContentAlignment="Left" VerticalContentAlignment="Center" Padding="15,0,0,0"/>
                <Expander Header="Администрирование"
                          Width="230"
                          Foreground="White"
                          Background="#1d2127">
                    <StackPanel>
                        <Button Content="Торговые автоматы"
                                Command="{Binding GoToMachinesCommand}"
                                Width="200" Margin="0,0,0,10"
                                Foreground="White" Background="#171717"/>
                        <Button Content="Список компаний"
                                Width="200"
                                Foreground="White"
                                Background="#171717"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <!-- Верхняя часть правой колонки (без изменений) -->
        <Border Grid.Row="1" Grid.Column="1" Background="#171717">
            <Grid ColumnDefinitions="80*, 20*">
                <TextBlock Text="ООО Торговые Автоматы"
                           Grid.Column="0"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Padding="5"
                           Foreground="White"/>
                <TextBlock Text="Главная"
                           Grid.Column="1"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"
                           Foreground="Gray"/>
            </Grid>
        </Border>

<!-- ========== ОСНОВНАЯ ОБЛАСТЬ КОНТЕНТА (ИСПРАВЛЕННАЯ) ========== -->
<Border Grid.Row="2" Grid.Column="1" Background="#d9d9d9">
    <Grid RowDefinitions="50, *">
        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="#d9d9d9">
            <TextBlock Text="Личный кабинет. Главная"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Padding="15"/>
        </Border>

        <!-- Скроллер с карточками в сетке -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <Grid Margin="20" RowDefinitions="Auto, Auto" ColumnDefinitions="*,*,*" RowSpacing="20" ColumnSpacing="20">

                <!-- Блок 1: Эффективность сети -->
                <Border Grid.Row="0" Grid.Column="0" Background="White" CornerRadius="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Эффективность сети"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#2c3e50"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,5"/>
                        <TextBlock Text="{Binding NetworkEfficiency, StringFormat='Работающих автоматов - {0:F0}%'}"
                                   Foreground="#7f8c8d" FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <Grid Height="150" Width="150" HorizontalAlignment="Center">
                            <lvc:PieChart Series="{Binding GaugeSeries}" Height="150" Width="150"/>
                            <TextBlock Text="{Binding NetworkEfficiency, StringFormat='{}{0:F0}%'}"
                                       FontSize="20" FontWeight="Bold"
                                       Foreground="#2c3e50"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Блок 2: Состояние сети -->
                <Border Grid.Row="0" Grid.Column="1" Background="White" CornerRadius="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Состояние сети"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#2c3e50"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        <lvc:PieChart Series="{Binding PieSeries}"
                                      Height="150" Width="150"
                                      HorizontalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Spacing="15"
                                    Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Background="#2ecc71" Width="12" Height="12" CornerRadius="2"/>
                                <TextBlock Text="Работают" FontSize="10" Foreground="#7f8c8d"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Background="#f39c12" Width="12" Height="12" CornerRadius="2"/>
                                <TextBlock Text="Обслуживание" FontSize="10" Foreground="#7f8c8d"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <Border Background="#e74c3c" Width="12" Height="12" CornerRadius="2"/>
                                <TextBlock Text="Сломаны" FontSize="10" Foreground="#7f8c8d"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Блок 3: Сводка -->
                <Border Grid.Row="0" Grid.Column="2" Background="White" CornerRadius="5" Padding="15">
                    <StackPanel>
                        <TextBlock Text="Сводка"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#2c3e50"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,15"/>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Продажи всего" Foreground="#34495e"/>
                            <TextBlock Grid.Column="1" Text="{Binding SummaryData.TotalSales, StringFormat='{}{0:N2} ₽'}" 
                                       Foreground="#2c3e50" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Инкассация сегодня" Foreground="#34495e"/>
                            <TextBlock Grid.Column="1" Text="{Binding SummaryData.CashCollection, StringFormat='{}{0:N2} ₽'}" 
                                       Foreground="#2c3e50" FontWeight="Bold"/>
                        </Grid>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="ТА на обслуживании" Foreground="#34495e"/>
                            <TextBlock Grid.Column="1" Text="{Binding SummaryData.MachinesUnderMaintenance}" 
                                       Foreground="#2c3e50" FontWeight="Bold"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Блок 4: Динамика продаж (занимает две колонки) -->
                <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="White" CornerRadius="5" Padding="15" MinHeight="460">
                    <Grid RowDefinitions="Auto, Auto, Auto, *">
                        <TextBlock Grid.Row="0"
                                   Text="Динамика продаж за последние 10 дней"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#2c3e50"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,5"/>
                        <TextBlock Grid.Row="1"
                                   Text="Данные по продажам за последние 10 дней"
                                   Foreground="#7f8c8d" FontSize="11"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,10"/>
                        
                        <StackPanel Grid.Row="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    Margin="0,0,0,15">
                            
                            <Button Margin="5"
                                    Padding="15,8"
                                    Background="{Binding IsAmountFilter, Converter={StaticResource InvertBool}}"
                                    Command="{Binding ShowQuantityCommand}">
                                <TextBlock Text="По количеству" Foreground="White"/>
                            </Button>
                            
                            <Button Margin="5"
                                    Padding="15,8"
                                    Background="{Binding IsAmountFilter, Converter={StaticResource InvertBool}, ConverterParameter=Invert}"
                                    Command="{Binding ShowAmountCommand}">
                                <TextBlock Text="По сумме" Foreground="White"/>
                            </Button>
                        </StackPanel>
                        
                        <lvc:CartesianChart Grid.Row="3"
                                            Series="{Binding SalesSeries}"
                                            XAxes="{Binding SalesXAxes}"
                                            YAxes="{Binding SalesYAxes}"
                                            Height="200"/>
                    </Grid>
                </Border>

                <!-- Блок 5: Новости -->
                <Border Grid.Row="1" Grid.Column="2" Background="White" CornerRadius="5" Padding="15" MinHeight="220">
                    <StackPanel>
                        <TextBlock Text="Новости"
                                   FontWeight="Bold" FontSize="14"
                                   Foreground="#2c3e50"
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>
                        <ItemsControl ItemsSource="{Binding News}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding PublishDate, StringFormat='dd.MM.yyyy'}"
                                                   Foreground="#7f8c8d" FontSize="12"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Title}"
                                                   Foreground="#3498db" FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Border>
    </Grid>
</UserControl>