<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="800"
             x:Class="UP_4.Views.MachineDetailView"
             xmlns:vm="clr-namespace:UP_4.ViewModels"
             x:DataType="vm:MachineDetailViewModel">

    <UserControl.Styles>
        <!-- Стиль для заголовков групп -->
        <Style Selector="TextBlock.groupHeader">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
        </Style>

        <!-- Стиль для подписей полей -->
        <Style Selector="Grid.labelGrid">
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>
        <Style Selector="TextBlock.labelText">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
        </Style>
        <Style Selector="TextBlock.requiredStar">
            <Setter Property="Foreground" Value="#e74c3c"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="3,0,0,0"/>
        </Style>

        <!-- Стиль для полей ввода -->
        <Style Selector="TextBox.field, ComboBox.field">
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
        </Style>

        <!-- Стиль для подсказок -->
        <Style Selector="TextBlock.hint">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="#7f8c8d"/>
            <Setter Property="Margin" Value="0,2,0,5"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto, *">
        <!-- Заголовок -->
        <Border Background="White" Padding="20,15" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,0,0,5">
                    <TextBlock Text="›" Foreground="#7f8c8d" FontSize="12"/>
                    <Button Content="Торговые автоматы"
                            Command="{Binding NavigateToVendingMachinesCommand}"
                            Background="Transparent" BorderThickness="0"
                            Foreground="#3498db" Padding="0" Cursor="Hand" FontSize="12"/>
                    <TextBlock Text="›" Foreground="#7f8c8d" FontSize="12"/>
                    <TextBlock Text="{Binding Title}" Foreground="#2c3e50" FontSize="12" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold" Foreground="#2c3e50"/>
            </StackPanel>
        </Border>

        <!-- Контент -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
            <StackPanel Margin="20" Spacing="20">

                <!-- Панель ошибок -->
                <Border Background="#ffeeee" BorderBrush="#ffcccc" BorderThickness="1" CornerRadius="5" Padding="15" IsVisible="{Binding HasError}">
                    <StackPanel>
                        <Grid ColumnDefinitions="Auto,*">
                            <TextBlock Grid.Column="0" Text="⚠️" FontSize="24" Foreground="#e74c3c" Margin="0,0,15,0" VerticalAlignment="Top"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="{Binding ErrorMessage}" Foreground="#c0392b" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                                <ItemsControl ItemsSource="{Binding ValidationErrors}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#e74c3c" Margin="0,2" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Grid>
                        <Button Content="Понятно" Command="{Binding ClearErrorsCommand}" HorizontalAlignment="Right" Background="#95a5a6" Foreground="White" BorderThickness="0" CornerRadius="3" Padding="25,8" Margin="0,15,0,0" Cursor="Hand" FontSize="12"/>
                    </StackPanel>
                </Border>

                <!-- Карточка формы -->
                <Border Background="White" CornerRadius="6" Padding="25" BoxShadow="0 2 8 0 rgba(0,0,0,0.1)">
                    <StackPanel>

                        <!-- Блок 1: Основная информация -->
                        <TextBlock Classes="groupHeader" Text="Основные данные"/>
                        <Grid ColumnDefinitions="*,20,*">
                            <!-- Левая колонка -->
                            <StackPanel Grid.Column="0">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Наименование ТА"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding Name}" Watermark="Введите наименование"/>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Производитель ТА"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding Companies}" SelectedItem="{Binding SelectedCompany}" PlaceholderText="Выберите производителя">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Модель ТА"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding Models}" SelectedItem="{Binding SelectedModel}" PlaceholderText="Выберите модель">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Номер автомата"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding SerialNumber}" Watermark="Введите серийный номер"/>
                            </StackPanel>

                            <!-- Правая колонка -->
                            <StackPanel Grid.Column="2">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Режим работы"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding WorkModes}" SelectedItem="{Binding SelectedWorkMode}" PlaceholderText="Выберите режим">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Место"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding Places}" SelectedItem="{Binding SelectedPlace}" PlaceholderText="Выберите место">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Приоритет обслуживания"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding Priorities}" SelectedItem="{Binding SelectedPriority}" PlaceholderText="Выберите приоритет">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,10,0,20" Background="#E0E0E0"/>

                        <!-- Блок 2: Адрес и Время работы -->
                        <TextBlock Classes="groupHeader" Text="Расположение и график"/>
                        <Grid ColumnDefinitions="*,20,*">
                            <StackPanel Grid.Column="0">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Адрес"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding Location}" Watermark="Введите адрес"/>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Координаты"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding Coordinates}" Watermark="54.5191,36.2802"/>
                                <TextBlock Classes="hint" Text="Формат: широта,долгота"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Время работы"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding WorkingHours}" Watermark="08:00-22:00"/>
                                <TextBlock Classes="hint" Text="Формат: ЧЧ:ММ-ЧЧ:ММ"/>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Часовой пояс"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding TimeZones}" SelectedItem="{Binding SelectedTimeZone}" PlaceholderText="Выберите часовой пояс">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,10,0,20" Background="#E0E0E0"/>

                        <!-- Блок 3: Технические данные и персонал -->
                        <TextBlock Classes="groupHeader" Text="Технические данные и персонал"/>
                        <Grid ColumnDefinitions="*,20,*">
                            <StackPanel Grid.Column="0">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Техник-оператор"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding Technicians}" SelectedItem="{Binding SelectedTechnician}" PlaceholderText="Выберите техника">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="ID кассы Kit Online"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding KitOnlineId}" Watermark="Введите ID кассы"/>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="RFID карты обслуживания"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding ServiceRfid}" Watermark="Введите RFID метку"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Менеджер"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding Managers}" SelectedItem="{Binding SelectedManager}" PlaceholderText="Выберите менеджера">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Инженер"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding Engineers}" SelectedItem="{Binding SelectedEngineer}" PlaceholderText="Выберите инженера">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding FullName}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="RFID карты инкассации"/>
                                </Grid>
                                <TextBox Classes="field" Text="{Binding CollectionRfid}" Watermark="Введите RFID метку"/>
                            </StackPanel>
                        </Grid>

                        <Separator Margin="0,10,0,20" Background="#E0E0E0"/>

                        <!-- Блок 4: Платежные системы и уведомления -->
                        <TextBlock Classes="groupHeader" Text="Платежные системы и уведомления"/>
                        <Grid ColumnDefinitions="*,20,*">
                            <StackPanel Grid.Column="0">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Платежные системы"/>
                                    <TextBlock Grid.Column="1" Classes="requiredStar" Text="*"/>
                                </Grid>
                                <ItemsControl ItemsSource="{Binding PaymentTypeSelections}" Margin="0,0,0,15">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding PaymentType.Name}" IsChecked="{Binding IsSelected}"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Шаблон крит. значений"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding CriticalThresholdTemplates}" SelectedItem="{Binding SelectedCriticalThresholdTemplate}" PlaceholderText="Выберите шаблон">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Шаблон уведомлений"/>
                                </Grid>
                                <ComboBox Classes="field" ItemsSource="{Binding NotificationTemplates}" SelectedItem="{Binding SelectedNotificationTemplate}" PlaceholderText="Выберите шаблон">
                                    <ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                                </ComboBox>

                                <Grid ColumnDefinitions="Auto,*" Classes="labelGrid">
                                    <TextBlock Grid.Column="0" Classes="labelText" Text="Примечания"/>
                                </Grid>
                                <TextBox Text="{Binding Notes}" AcceptsReturn="True" Height="80" VerticalContentAlignment="Top" Padding="5" Watermark="Введите примечания"/>
                            </StackPanel>
                        </Grid>

                        <!-- Кнопки действий -->
                        <Border Background="#F9F9F9" CornerRadius="5" Padding="15" Margin="0,30,0,0" BoxShadow="0 2 4 0 rgba(0,0,0,0.05)">
                            <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                                <TextBlock Grid.Column="0" Text="* Обязательные поля" Foreground="#e74c3c" VerticalAlignment="Center" FontSize="12"/>

                                <Button Grid.Column="1" Content="Отмена" Command="{Binding CancelCommand}" Padding="40,10" Background="#95a5a6" Foreground="White" BorderThickness="0" CornerRadius="4" Width="150" Height="40" Cursor="Hand" FontSize="14" Margin="0,0,10,0"/>

                                <Button Grid.Column="2" Content="Сохранить" Command="{Binding SaveCommand}" Padding="40,10" Background="#27ae60" Foreground="White" BorderThickness="0" CornerRadius="4" Width="150" Height="40" Cursor="Hand" FontSize="14"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>