<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="UP_4.Views.MainPageView"
             xmlns:vm="clr-namespace:UP_4.ViewModels"
             x:DataType="vm:MainPageViewModel">

    <Grid RowDefinitions="60, 40, *" ColumnDefinitions="250, *">

		<Border Grid.Row="0" Grid.ColumnSpan="2" Background="White" >
            <Grid ColumnDefinitions="80*, 20*">
				<Image Grid.Column="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"
                       Source="/Assets/Logo.png"/>
                <Border Grid.Column="1">
                    <Grid ColumnDefinitions="30*, 70*">
                        <Image Grid.Column="0" Source="{Binding CurrentUser.Image, Converter={StaticResource Base64ToImageConverter}}"/>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
							<TextBlock Text="{Binding CurrentUser.ShortName}"/>
                            <TextBlock Text="{Binding CurrentUser.IdRoleNavigation.Name}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

       <Grid Grid.Row="1" ColumnDefinitions="70*, 30*">
            <Border Grid.Column="0" Background="#1d2127">
                <TextBlock Text="Навигация"
                           HorizontalAlignment="Left"
                           VerticalAlignment="Center"
                           Foreground="White"
                           Padding="5"/>
            </Border>

            <Border Grid.Column="1" Background="#171717">
                <TextBlock Text="☰"
                           Foreground="White"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>

        <Border Grid.Column="0" Grid.Row="2" Background="#1d2127">
            <Border.Styles>
                <Style Selector="Expander /template/ ToggleButton">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="#171717"/>
                </Style>
            </Border.Styles>

            <StackPanel Margin="10">
                <Button Content="Главная"
                        Margin="0,0,0,10"
                        Width="230"
                        Height="50"
                        Foreground="White"
                        Background="#171717"
                        HorizontalContentAlignment="Left"
                        VerticalContentAlignment="Center"
                        Padding="15,0,0,0"/>

                <Expander Header="Администрирование"
                          Width="230"
                          Foreground="White"
                          Background="#1d2127">
                    <StackPanel>
                        <Button Content="Автоматы"
                                Width="200"
                                Margin="0,0,0,10"
                                Foreground="White"
                                Background="#171717"/>

                        <Button Content="Пулеметы"
                                Width="200"
                                Foreground="White"
                                Background="#171717"/>
                    </StackPanel>
                </Expander>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Grid.Column="1" Background="#171717">
            <Grid ColumnDefinitions="80*, 20*">
				<TextBlock Text="ООО Торговые Автоматы"
                       Grid.Column="0"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Padding="5"
                       Foreground="White"/>
                <TextBlock Text="Главная"
                       Grid.Column="1"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Foreground="Gray"/>
            </Grid>
        </Border>

     

        <Border Grid.Row="2" Grid.Column="1" Background="#d9d9d9"> 
            <Grid RowDefinitions="50, *">
				<Border Grid.Row="0" Background="#d9d9d9">
					<TextBlock Text="Личный кабинет. Главная"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Padding="15"/>
                </Border>

                <StackPanel Grid.Row="1">
					
                </StackPanel>
            </Grid>
        </Border>
    </Grid>

</UserControl>
